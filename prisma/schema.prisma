generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Employee {
  id                 String          @id @default(auto()) @map("_id") @db.ObjectId
  fullName           String
  email              String          @unique
  phone              String?
  department         String?
  position           String?
  role               String          @default("employee")
  passwordHash       String
  leaveBalance       Int             @default(18)
  mustChangePassword Boolean         @default(false)
  status             String          @default("active")
  deletedAt          DateTime?
  createdAt          DateTime        @default(now())

  attendance         Attendance[]
  leaveRequests      LeaveRequest[]
  loginHistory       LoginHistory[]
  suspiciousLogs     SuspiciousLog[]
  profile            EmployeeProfile?
  documents          EmployeeDocument[]
}

model Attendance {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  employeeId         String    @db.ObjectId
  date               DateTime
  checkIn            DateTime?
  checkOut           DateTime?
  hours              Float?
  status             String    @default("present")
  latitude           Float?
  longitude          Float?
  ipAddress          String?
  device             String?
  distanceFromOffice Float?
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())

  employee           Employee  @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
}

model LeaveRequest {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  employeeId String    @db.ObjectId
  startDate  DateTime
  endDate    DateTime
  days       Int       @default(1)
  reason     String
  status     String    @default("pending")
  approvedBy String?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())

  employee   Employee  @relation(fields: [employeeId], references: [id])
}

model LoginHistory {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  employeeId String   @db.ObjectId
  ipAddress  String?
  device     String?
  browser    String?
  loginTime  DateTime @default(now())
  success    Boolean  @default(true)

  employee   Employee @relation(fields: [employeeId], references: [id])
}

model SuspiciousLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  employeeId  String   @db.ObjectId
  type        String
  description String
  ipAddress   String?
  createdAt   DateTime @default(now())

  employee    Employee @relation(fields: [employeeId], references: [id])
}

model Department {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String
}

model Role {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String
}

model Startup {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  startupName  String
  founderName  String
  founderEmail String?
  founderPhone String?
  program      String    @default("Diksuchi")
  stage        String    @default("Idea")
  mentor       String?
  description  String?
  fundingStage String    @default("Bootstrapped")
  progress     Int       @default(0)
  status       String    @default("Active")
  website      String?
  logo         String?
  industry     String?
  teamSize     Int?
  location     String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Archive {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  sourceTable    String
  sourceId       String
  snapshot       Json
  archivedBy     String    @db.ObjectId
  archivedAt     DateTime  @default(now())
  retentionUntil DateTime?
}

model AuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  adminId    String   @db.ObjectId
  action     String
  resource   String
  resourceId String
  details    Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
}

model Notification {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  recipientId   String   @db.ObjectId
  title         String
  message       String
  type          String   @default("info")
  isRead        Boolean  @default(false)
  link          String?
  createdAt     DateTime @default(now())
}

model Settings {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model EmployeeProfile {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  employeeId          String   @unique @db.ObjectId
  
  // Personal
  dateOfBirth         DateTime?
  gender              String?
  nationality         String?
  maritalStatus       String?
  
  // Address
  addressLine1        String?
  addressLine2        String?
  city                String?
  state               String?
  postalCode          String?
  country             String?
  
  // Emergency Contact
  emergencyName       String?
  emergencyRelation   String?
  emergencyPhone      String?
  emergencyEmail      String?
  
  // Education
  highestEducation    String?
  institution         String?
  fieldOfStudy        String?
  graduationYear      Int?
  
  // Professional
  skills              String[]  @default([])
  certifications      String[]  @default([])
  experience          String?
  bio                 String?
  
  // Avatar
  avatar              String?  // Base64 encoded image
  
  employee            Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model EmployeeDocument {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  employeeId          String   @db.ObjectId
  documentName        String
  documentType        String   // "certificate", "degree", "resume", "other"
  documentUrl         String   // Base64 encoded file
  verificationStatus  String   @default("pending")  // pending, verified, rejected
  uploadedAt          DateTime @default(now())
  verifiedAt          DateTime?
  verifiedBy          String?  @db.ObjectId
  deletedAt           DateTime?
  
  employee            Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}
