# App branding
APP_NAME="AnveCore HRMS"
NEXT_PUBLIC_APP_URL="https://anvecore.vercel.app"

# MongoDB Atlas connection string
DATABASE_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT secret — use a long random string (min 32 chars) in production
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Google Maps API key (optional — for live attendance map)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# SMTP email — for sending employee welcome/credential emails (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
SMTP_FROM=AnveCore HRMS <your@email.com>
