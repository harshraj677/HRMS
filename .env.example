# MongoDB connection string (from MongoDB Atlas → Connect → Drivers)
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?appName=<AppName>
DATABASE_URL="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=Anvesana"

# JWT secret — use a long random string in production
JWT_SECRET="your_super_secure_jwt_secret_min_32_chars"

# Google Maps (optional — for attendance map feature)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your_google_maps_api_key"

# SMTP email (optional — for employee credential emails)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"
SMTP_FROM="Anvesana <your_email@gmail.com>"
